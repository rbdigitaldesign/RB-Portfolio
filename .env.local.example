# ── Firebase (public — safe to commit) ───────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAm2iVhW1oc70gRXxet1ocqz4NCF1cG1xY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=design-portfolio-v2.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=design-portfolio-v2
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=design-portfolio-v2.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=738515003817
NEXT_PUBLIC_FIREBASE_APP_ID=1:738515003817:web:e996b105dcaf8f4e827cb8
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-2D7VV545RP

# ── Firebase Admin — SERVICE ACCOUNT (server-only, keep secret) ──────────────
# Required for Vercel (and any non-GCP host).
# How to get it:
#   1. Go to Firebase Console → Project Settings → Service accounts
#   2. Click "Generate new private key" → download the JSON file
#   3. Paste the ENTIRE JSON content as a single line value below
#      (Vercel handles multi-line; locally you can use a single-line JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── reCAPTCHA v3 ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LegaK0rAAAAAHQa1ntdpOpu9eC1gZAbmgbeDDZU
# Secret key — retrieve from Google reCAPTCHA admin console or Firebase secrets
RECAPTCHA_SECRET_KEY=

# ── Email service (Resend) ───────────────────────────────────────────────────
# Retrieve from https://resend.com/api-keys or Firebase project secrets
RESEND_API_KEY=

# ── Contact form (optional — defaults shown) ─────────────────────────────────
